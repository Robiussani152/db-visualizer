{
    "version": "1.0.0",
    "name": "naimul/db-visualizer",
    "description": "Laravel Database & Code Intelligence Visualizer (N+1, Relations, Performance Analyzer)",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Naimul Islam",
            "email": "naimcse56@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/filesystem": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/cache": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/database": "^10.0 || ^11.0 || ^12.0 || ^13.0"
    },
    "autoload": {
        "psr-4": {
            "Naimul\\DbVisualizer\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Naimul\\DbVisualizer\\DbVisualizerServiceProvider"
            ]
        }
    },
    "require-dev": {
        "laravel/pint": "^1.27.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.0|^3.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Naimul\\DbVisualizer\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
